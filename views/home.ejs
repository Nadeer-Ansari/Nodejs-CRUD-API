<script>
// Function to fetch users from API - NO ALERTS
async function fetchUsers() {
    try {
        const response = await fetch('/api/users');
        if (!response.ok) {
            console.error(`HTTP error! status: ${response.status}`);
            return [];
        }
        const data = await response.json();
        return Array.isArray(data) ? data : [];
    } catch (error) {
        console.error('Error fetching users:', error);
        return [];
    }
}

// Function to update statistics
async function updateStatistics() {
    try {
        const users = await fetchUsers();
        
        if (!users || users.length === 0) {
            // Show empty state, not error
            document.getElementById('totalUsers').textContent = '0';
            document.getElementById('avgAge').textContent = '0';
            document.getElementById('totalPlaces').textContent = '0';
            document.getElementById('recentUsers').textContent = '0';
            
            document.getElementById('recentUsersList').innerHTML = `
                <tr>
                    <td colspan="3" class="text-center text-muted">
                        No users found. <a href="/adduser">Add your first user!</a>
                    </td>
                </tr>
            `;
            
            document.getElementById('suggestionsList').innerHTML = `
                <div class="text-center p-3">
                    <i class="fas fa-info-circle" style="font-size: 2rem; color: #667eea;"></i>
                    <p class="mt-2">Add your first user to see insights!</p>
                    <a href="/adduser" class="btn-gradient-outline btn-sm">Add User</a>
                </div>
            `;
            return;
        }
        
        // Filter valid users
        const validUsers = users.filter(u => u && u.name);
        
        if (validUsers.length === 0) {
            document.getElementById('totalUsers').textContent = '0';
            document.getElementById('avgAge').textContent = '0';
            document.getElementById('totalPlaces').textContent = '0';
            document.getElementById('recentUsers').textContent = '0';
            return;
        }
        
        // Total users
        document.getElementById('totalUsers').textContent = validUsers.length;
        
        // Average age
        const totalAge = validUsers.reduce((sum, user) => sum + (user.age || 0), 0);
        const avgAge = Math.round(totalAge / validUsers.length);
        document.getElementById('avgAge').textContent = avgAge || '0';
        
        // Unique places
        const places = [...new Set(validUsers.map(user => user.place).filter(place => place))];
        document.getElementById('totalPlaces').textContent = places.length;
        
        // Recent users count
        document.getElementById('recentUsers').textContent = Math.min(validUsers.length, 5);
        
        // Update recent users table
        updateRecentUsers(validUsers);
        
        // Update suggestions
        updateSuggestions(validUsers);
        
    } catch (error) {
        console.error('Error updating statistics:', error);
        // Silently fail - no alerts
        document.getElementById('totalUsers').textContent = '0';
        document.getElementById('avgAge').textContent = '0';
        document.getElementById('totalPlaces').textContent = '0';
        document.getElementById('recentUsers').textContent = '0';
    }
}

// Function to update recent users table
function updateRecentUsers(users) {
    const tbody = document.getElementById('recentUsersList');
    
    if (users.length === 0) {
        tbody.innerHTML = `
            <tr>
                <td colspan="3" class="text-center text-muted">
                    No users found. <a href="/adduser">Add your first user!</a>
                </td>
            </tr>
        `;
        return;
    }
    
    // Get last 5 users and reverse
    const recentUsers = [...users].slice(-5).reverse();
    
    tbody.innerHTML = recentUsers.map(user => `
        <tr>
            <td><strong>${escapeHtml(user.name || 'Unknown')}</strong></td>
            <td>${user.age || '?'}</td>
            <td><i class="fas fa-map-pin"></i> ${escapeHtml(user.place || 'Unknown')}</td>
        </tr>
    `).join('');
}

// Function to update suggestions
function updateSuggestions(users) {
    const suggestionsDiv = document.getElementById('suggestionsList');
    
    if (users.length === 0) {
        suggestionsDiv.innerHTML = `
            <div class="text-center p-3">
                <i class="fas fa-info-circle" style="font-size: 2rem; color: #667eea;"></i>
                <p class="mt-2">Add your first user to see insights!</p>
                <a href="/adduser" class="btn-gradient-outline btn-sm">Add User</a>
            </div>
        `;
        return;
    }
    
    const avgAge = users.reduce((sum, u) => sum + (u.age || 0), 0) / users.length;
    const uniquePlaces = [...new Set(users.map(u => u.place).filter(p => p))];
    const suggestions = [];
    
    if (users.length < 5) {
        suggestions.push({
            icon: '🚀',
            title: 'Quick Start',
            description: `You have ${users.length} user${users.length !== 1 ? 's' : ''}. Add more to unlock analytics!`,
            action: '/adduser'
        });
    }
    
    if (avgAge < 25 && users.length > 0) {
        suggestions.push({
            icon: '🎓',
            title: 'Young Community',
            description: 'Your users are mostly young. Consider modern engagement!',
            action: '/showuser'
        });
    } else if (avgAge > 45 && users.length > 0) {
        suggestions.push({
            icon: '👴',
            title: 'Experienced Users',
            description: 'Senior user base detected. Consider accessibility features!',
            action: '/showuser'
        });
    }
    
    if (uniquePlaces.length > 3) {
        suggestions.push({
            icon: '🌍',
            title: 'Global Reach',
            description: `Users from ${uniquePlaces.length} different locations!`,
            action: '/showuser'
        });
    }
    
    if (suggestions.length === 0 && users.length >= 5) {
        suggestions.push({
            icon: '💡',
            title: 'Pro Tip',
            description: 'Regularly update user data to keep your dashboard accurate!',
            action: '/showuser'
        });
    }
    
    suggestionsDiv.innerHTML = suggestions.map(s => `
        <div class="mb-3 p-3" style="background: #f8f9fa; border-radius: 10px; cursor: pointer;" onclick="window.location.href='${s.action}'">
            <div class="d-flex align-items-center">
                <div style="font-size: 2rem; margin-right: 15px;">${s.icon}</div>
                <div>
                    <h6 class="mb-1">${s.title}</h6>
                    <p class="mb-0 small text-muted">${s.description}</p>
                </div>
            </div>
        </div>
    `).join('');
}

function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

// Load data when page loads
document.addEventListener('DOMContentLoaded', function() {
    updateStatistics();
    // Refresh every 30 seconds
    setInterval(updateStatistics, 30000);
});
</script>

