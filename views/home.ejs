<%- include('header.ejs') %>

    <div class="container">
        <!-- Hero Section -->
        <div class="text-center mb-5 animate-fadeInUp">
            <div class="float-animation">
                <i class="fas fa-chart-line" style="font-size: 4rem; color: white; opacity: 0.9;"></i>
            </div>
            <h1
                style="font-size: 3.5rem; color: white; text-shadow: 2px 4px 10px rgba(0,0,0,0.3); font-weight: 800; margin-top: 20px;">
                Welcome to <span
                    style="background: linear-gradient(135deg, #fff, #e0c3ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">UserHub</span>
            </h1>
            <p style="color: white; font-size: 1.2rem; opacity: 0.95; margin-top: 15px;">
                The Ultimate User Management System with Real-time Analytics
            </p>
            <div class="mt-4">
                <a href="/showuser" class="btn-gradient" style="text-decoration: none; margin: 0 10px;">
                    <i class="fas fa-users"></i> Browse Users
                </a>
                <a href="/adduser" class="btn-outline-gradient" style="text-decoration: none; margin: 0 10px;">
                    <i class="fas fa-plus-circle"></i> Quick Add
                </a>
            </div>
        </div>

        <!-- Statistics Section -->
        <div class="row mb-5">
            <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.1s">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-number" id="totalUsers">0</div>
                    <p class="text-muted mb-0">Total Users</p>
                    <small class="text-success"><i class="fas fa-arrow-up"></i> Active</small>
                </div>
            </div>
            <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.2s">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <div class="stat-number" id="avgAge">0</div>
                    <p class="text-muted mb-0">Average Age</p>
                    <small class="text-info"><i class="fas fa-calendar"></i> Years</small>
                </div>
            </div>
            <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.3s">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-globe"></i>
                    </div>
                    <div class="stat-number" id="totalPlaces">0</div>
                    <p class="text-muted mb-0">Cities Covered</p>
                    <small class="text-warning"><i class="fas fa-map-marker-alt"></i> Worldwide</small>
                </div>
            </div>
            <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.4s">
                <div class="stat-card">
                    <div class="stat-icon">
                        <i class="fas fa-clock"></i>
                    </div>
                    <div class="stat-number" id="recentUsers">0</div>
                    <p class="text-muted mb-0">Recent Joiners</p>
                    <small class="text-primary"><i class="fas fa-star"></i> Last 5</small>
                </div>
            </div>
        </div>

        <!-- Recent Users & Insights -->
        <div class="row">
            <div class="col-lg-8 mb-4 animate-fadeInUp" style="animation-delay: 0.5s">
                <div class="glass-card">
                    <div class="p-4">
                        <h4 class="mb-3">
                            <i class="fas fa-history" style="color: #667eea;"></i>
                            Recently Joined Members
                        </h4>
                        <div class="table-responsive">
                            <table class="table table-modern">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-user"></i> Name</th>
                                        <th><i class="fas fa-calendar"></i> Age</th>
                                        <th><i class="fas fa-location-dot"></i> Location</th>
                                    </tr>
                                </thead>
                                <tbody id="recentUsersList">
                                    <tr>
                                        <td colspan="3" class="text-center">
                                            <div class="loading-spinner"></div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/showuser" class="btn-outline-gradient btn-sm">View All Members →</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4 animate-fadeInUp" style="animation-delay: 0.6s">
                <div class="glass-card">
                    <div class="p-4">
                        <h4 class="mb-3">
                            <i class="fas fa-brain" style="color: #667eea;"></i>
                            AI Insights
                        </h4>
                        <div id="suggestionsList">
                            <div class="text-center">
                                <div class="loading-spinner"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function fetchUsers() {
            try {
                const response = await fetch('/api/users');
                if (!response.ok) return [];
                const data = await response.json();
                return Array.isArray(data) ? data : [];
            } catch (error) {
                console.error('Error:', error);
                return [];
            }
        }

        async function updateStatistics() {
            const users = await fetchUsers();

            if (!users || users.length === 0) {
                document.getElementById('totalUsers').textContent = '0';
                document.getElementById('avgAge').textContent = '0';
                document.getElementById('totalPlaces').textContent = '0';
                document.getElementById('recentUsers').textContent = '0';
                document.getElementById('recentUsersList').innerHTML = `
            <tr><td colspan="3" class="text-center">✨ No users yet. <a href="/adduser">Create your first user!</a></td></tr>
        `;
                return;
            }

            const validUsers = users.filter(u => u && u.name);
            document.getElementById('totalUsers').textContent = validUsers.length;

            const totalAge = validUsers.reduce((sum, u) => sum + (u.age || 0), 0);
            const avgAge = validUsers.length > 0 ? Math.round(totalAge / validUsers.length) : 0;
            document.getElementById('avgAge').textContent = avgAge;

            const places = [...new Set(validUsers.map(u => u.place).filter(p => p))];
            document.getElementById('totalPlaces').textContent = places.length;
            document.getElementById('recentUsers').textContent = Math.min(validUsers.length, 5);

            const recentUsers = [...validUsers].slice(-5).reverse();
            document.getElementById('recentUsersList').innerHTML = recentUsers.map(user => `
        <tr>
            <td><strong>${escapeHtml(user.name)}</strong><br><small class="text-muted">#${String(user._id).slice(-6)}</small></td>
            <td><span class="badge" style="background: linear-gradient(135deg, #667eea, #764ba2);">${user.age} yrs</span></td>
            <td><i class="fas fa-map-pin"></i> ${escapeHtml(user.place)}</td>
        </tr>
    `).join('');

            updateSuggestions(validUsers);
        }

        function updateSuggestions(users) {
            const div = document.getElementById('suggestionsList');
            const suggestions = [];

            if (users.length === 0) {
                div.innerHTML = `
            <div class="text-center p-4">
                <i class="fas fa-rocket" style="font-size: 3rem; color: #667eea;"></i>
                <p class="mt-3">Ready to start? Add your first user!</p>
                <a href="/adduser" class="btn-gradient btn-sm">Get Started</a>
            </div>
        `;
                return;
            }

            if (users.length < 5) {
                suggestions.push({ icon: '🚀', title: 'Growth Opportunity', desc: `You have ${users.length} users. Add ${5 - users.length} more to unlock insights!`, action: '/adduser' });
            }

            const avgAge = users.reduce((sum, u) => sum + (u.age || 0), 0) / users.length;
            if (avgAge < 25) suggestions.push({ icon: '🎓', title: 'Young Community', desc: 'Your users are young. Consider modern engagement strategies!', action: '/showuser' });

            const places = [...new Set(users.map(u => u.place))];
            if (places.length > 3) suggestions.push({ icon: '🌍', title: 'Global Reach', desc: `Users from ${places.length} different locations!`, action: '/showuser' });

            if (suggestions.length === 0) {
                suggestions.push({ icon: '💎', title: 'Pro Tip', desc: 'Keep your data updated for better analytics!', action: '/showuser' });
            }

            div.innerHTML = suggestions.map(s => `
        <div class="mb-3 p-3" style="background: rgba(102,126,234,0.1); border-radius: 12px; cursor: pointer;" onclick="window.location.href='${s.action}'">
            <div class="d-flex align-items-center">
                <div style="font-size: 2rem; margin-right: 15px;">${s.icon}</div>
                <div>
                    <h6 class="mb-1">${s.title}</h6>
                    <p class="mb-0 small text-muted">${s.desc}</p>
                </div>
            </div>
        </div>
    `).join('');
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateStatistics();
            setInterval(updateStatistics, 30000);
        });
    </script>

    <%- include('footer.ejs') %>