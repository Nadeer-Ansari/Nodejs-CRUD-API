    <!-- Recent Users & Suggestions -->
    <div class="row">
        <div class="col-lg-8 mb-4 animate-fadeInUp" style="animation-delay: 0.5s">
            <div class="card-modern">
                <div class="card-header bg-white border-0 p-4">
                    <h4 class="mb-0">
                        <i class="fas fa-clock"></i> Recent Users
                    </h4>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-modern">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Age</th>
                                    <th>Location</th>
                                </tr>
                            </thead>
                            <tbody id="recentUsersList">
                                <tr>
                                    <td colspan="3" class="text-center">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <p class="mt-2">Loading users...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-center mt-3">
                        <a href="/showuser" class="btn-gradient-outline">View All Users →</a>
                    </div>
