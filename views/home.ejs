<%- include('header.ejs') %>
    <style>
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 80px 0;
            border-radius: 20px;
            margin-top: 20px;
        }

        .stat-card {
            background: white;
            border-radius: 15px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease;
            text-align: center;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: bold;
            color: #667eea;
        }

        .feature-icon {
            font-size: 3rem;
            color: #667eea;
            margin-bottom: 20px;
        }

        .action-buttons .btn {
            margin: 10px;
            padding: 12px 30px;
            border-radius: 25px;
            font-weight: 600;
        }

        .recent-users-table {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        .welcome-message {
            animation: fadeInUp 0.8s ease;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .suggestion-card {
            border-left: 4px solid #667eea;
            transition: all 0.3s ease;
        }

        .suggestion-card:hover {
            transform: translateX(10px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        }
    </style>

    <div class="container mt-4">
        <!-- Hero Section -->
        <div class="hero-section text-center fade-in">
            <div class="container">
                <h1 class="display-4 welcome-message">Welcome to User Management System</h1>
                <p class="lead mt-3">Efficiently manage your users with our modern and intuitive interface</p>
                <div class="action-buttons mt-4">
                    <a href="/showuser" class="btn btn-light btn-lg">View All Users</a>
                    <a href="/adduser" class="btn btn-outline-light btn-lg">Add New User</a>
                </div>
            </div>
        </div>

        <!-- Statistics Section -->
        <div class="row mt-5">
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number" id="totalUsers">0</div>
                    <h5>Total Users</h5>
                    <p class="text-muted">Registered members</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number" id="avgAge">0</div>
                    <h5>Average Age</h5>
                    <p class="text-muted">Years old</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number" id="totalPlaces">0</div>
                    <h5>Cities</h5>
                    <p class="text-muted">Different locations</p>
                </div>
            </div>
            <div class="col-md-3 mb-4">
                <div class="stat-card">
                    <div class="stat-number" id="recentCount">0</div>
                    <h5>Recent Users</h5>
                    <p class="text-muted">Last 30 days</p>
                </div>
            </div>
        </div>

        <!-- Features Section -->
        <div class="row mt-4 mb-5">
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="feature-icon">👥</div>
                    <h4>User Management</h4>
                    <p>Add, edit, and delete users with ease using our intuitive interface</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="feature-icon">📊</div>
                    <h4>Analytics</h4>
                    <p>Track user statistics and gain insights about your user base</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="text-center">
                    <div class="feature-icon">🔒</div>
                    <h4>Secure</h4>
                    <p>Your data is safe and secure with our robust system</p>
                </div>
            </div>
        </div>

        <!-- Recent Users & Suggestions Section -->
        <div class="row mt-4">
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">📋 Recent Users</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover" id="recentUsersTable">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Age</th>
                                        <th>Place</th>
                                    </tr>
                                </thead>
                                <tbody id="recentUsersList">
                                    <tr>
                                        <td colspan="3" class="text-center">Loading...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/showuser" class="btn btn-sm btn-primary">View All Users →</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">💡 Suggestions For You</h5>
                    </div>
                    <div class="card-body" id="suggestionsContainer">
                        <div id="suggestionsList"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/script.js"></script>
    <%- include('footer.ejs') %>