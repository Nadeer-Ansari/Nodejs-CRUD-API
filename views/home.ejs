        <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.2s">
            <div class="card-modern text-center p-4">
                <i class="fas fa-calendar-alt" style="font-size: 3rem; color: #667eea;"></i>
                <h3 class="mt-3" id="avgAge">--</h3>
                <p class="text-muted mb-0">Average Age</p>
            </div>
        </div>
        <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.3s">
            <div class="card-modern text-center p-4">
                <i class="fas fa-map-marker-alt" style="font-size: 3rem; color: #667eea;"></i>
                <h3 class="mt-3" id="totalPlaces">--</h3>
                <p class="text-muted mb-0">Cities</p>
            </div>
        </div>
        <div class="col-md-3 mb-4 animate-fadeInUp" style="animation-delay: 0.4s">
            <div class="card-modern text-center p-4">
                <i class="fas fa-chart-line" style="font-size: 3rem; color: #667eea;"></i>
                <h3 class="mt-3" id="recentUsers">--</h3>
                <p class="text-muted mb-0">Recent Users</p>
            </div>
