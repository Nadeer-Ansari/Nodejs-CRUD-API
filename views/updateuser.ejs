<%- include('header.ejs') %>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card-modern animate-fadeInUp">
                    <div class="card-header bg-white border-0 p-4">
                        <h3 class="mb-0">
                            <i class="fas fa-edit"></i> Edit User
                        </h3>
                        <p class="text-muted mt-2">Update user information</p>
                    </div>
                    <div class="card-body p-4">
                        <form action="/updateaction/<%= user._id %>" method="post">
                            <div class="mb-4">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-user"></i> Full Name
                                </label>
                                <input type="text" name="name" class="form-control form-control-modern"
                                    value="<%= user.name %>" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar"></i> Age
                                </label>
                                <input type="number" name="age" class="form-control form-control-modern"
                                    value="<%= user.age %>" required>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-map-marker-alt"></i> Place
                                </label>
                                <input type="text" name="place" class="form-control form-control-modern"
                                    value="<%= user.place %>" required>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <a href="/showuser" class="btn-gradient-outline" style="text-decoration: none;">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                                <button type="submit" class="btn-gradient">
                                    <i class="fas fa-save"></i> Update User
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('footer.ejs') %>