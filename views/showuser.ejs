<%- include('header.ejs') %>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: white;">
            <i class="fas fa-users"></i> User Management
        </h2>
        <a href="/adduser" class="btn-gradient" style="text-decoration: none;">
            <i class="fas fa-user-plus"></i> Add New User
        </a>
    </div>

    <div class="card-modern animate-fadeInUp">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th><i class="fas fa-user"></i> Name</th>
                            <th><i class="fas fa-calendar"></i> Age</th>
                            <th><i class="fas fa-map-marker-alt"></i> Place</th>
                            <th><i class="fas fa-cog"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(data && data.length > 0) { %>
                            <% data.forEach(function(user, index) { %>
                                <tr class="animate-fadeInUp" style="animation-delay: <%= index * 0.05 %>s">
                                    <td>
                                        <strong><%= user.name %></strong>
                                        <br>
                                        <small class="text-muted">ID: <%= user._id.toString().slice(-6) %></small>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary rounded-pill"><%= user.age %> years</span>
                                    </td>
                                    <td><i class="fas fa-map-pin"></i> <%= user.place %></td>
                                    <td>
                                        <a href="/edituser/<%= user._id %>" class="btn btn-warning btn-sm me-2">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                        <button onclick="deleteUser('<%= user._id %>')" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="fas fa-inbox" style="font-size: 3rem; color: #ccc;"></i>
                                    <p class="mt-3">No users found. <a href="/adduser">Add your first user!</a></p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
function deleteUser(id) {
    if(confirm('Are you sure you want to delete this user?')) {
        fetch(`/deleteaction/${id}`, { method: 'DELETE' })
            .then(() => {
                showToast('User deleted successfully!', 'success');
                setTimeout(() => location.reload(), 1000);
            })
            .catch(err => {
                showToast('Error deleting user', 'error');
            });
    }
}

function showToast(message, type) {
    const toast = document.createElement('div');
    toast.className = 'toast-notification';
    toast.style.background = type === 'success' ? '#28a745' : '#dc3545';
    toast.style.color = 'white';
    toast.innerHTML = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}
</script>

<%- include('footer.ejs') %>