<%- include('header.ejs') %>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 style="color: white;">
            <i class="fas fa-users"></i> User Management
        </h2>
        <a href="/adduser" class="btn-gradient" style="text-decoration: none;">
            <i class="fas fa-user-plus"></i> Add New User
        </a>
    </div>

    <div class="card-modern animate-fadeInUp">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-modern mb-0">
                    <thead>
                        <tr>
                            <th><i class="fas fa-user"></i> Name</th>
                            <th><i class="fas fa-calendar"></i> Age</th>
                            <th><i class="fas fa-map-marker-alt"></i> Place</th>
                            <th><i class="fas fa-cog"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% 
                        // Filter valid users safely
                        let validUsers = [];
                        if(data && Array.isArray(data)) {
                            validUsers = data.filter(function(user) {
                                return user && typeof user === 'object' && user.name;
                            });
                        }
                        
                        if(validUsers.length > 0) { 
                            for(var i = 0; i < validUsers.length; i++) { 
                                var user = validUsers[i];
                                var userId = user._id ? String(user._id) : '';
                                var userName = user.name || 'Unknown';
                                var userAge = user.age || '?';
                                var userPlace = user.place || 'Unknown';
                        %>
                            <tr class="animate-fadeInUp">
                                <td>
                                    <strong><%= userName %></strong>
                                    <% if(userId) { %>
                                        <br>
                                        <small class="text-muted">ID: <%= userId.slice(-6) %></small>
                                    <% } %>
                                </td>
                                <td>
                                    <span class="badge bg-primary rounded-pill">
                                        <%= userAge %> years
                                    </span>
                                </td>
                                <td>
                                    <i class="fas fa-map-pin"></i> <%= userPlace %>
                                </td>
                                <td>
                                    <a href="/edituser/<%= userId %>" class="btn btn-warning btn-sm me-2">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <button onclick="deleteUser('<%= userId %>')" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        <% } } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5">
                                    <i class="fas fa-inbox" style="font-size: 3rem; color: #ccc;"></i>
                                    <p class="mt-3">No users found. <a href="/adduser">Add your first user!</a></p>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
function deleteUser(id) {
    if (!id || id === '') {
        alert('Invalid user ID');
        return;
    }
    
    if (confirm('Are you sure you want to delete this user?')) {
        fetch(`/deleteaction/${id}`, { 
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.message) {
                alert('User deleted successfully!');
                window.location.reload();
            } else {
                alert('Error: ' + (data.error || 'Unknown error'));
            }
        })
        .catch(err => {
            console.error('Delete error:', err);
            alert('Error deleting user');
        });
    }
}
</script>

<%- include('footer.ejs') %>